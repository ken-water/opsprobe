{
  "name": "@opsprobe/local-service",
  "private": true,
  "version": "0.3.0-dev",
  "type": "module",
  "scripts": {
    "inspect-run": "node --experimental-strip-types ./src/main.ts inspect-run",
    "inspect-preview": "node --experimental-strip-types ./src/main.ts inspect-preview",
    "inspection-history": "node --experimental-strip-types ./src/main.ts inspection-history",
    "serve": "node --experimental-strip-types ./src/main.ts serve",
    "status": "node --experimental-strip-types ./src/main.ts status",
    "stop": "node --experimental-strip-types ./src/main.ts stop"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@opsprobe/checks": "*",
    "@opsprobe/core": "*",
    "@opsprobe/runner": "*",
    "@opsprobe/storage": "*"
  }
}
