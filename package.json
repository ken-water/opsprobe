{
  "name": "opsprobe",
  "private": true,
  "version": "0.2.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "desktop:dev": "npm --workspace @opsprobe/desktop run tauri dev",
    "desktop:build": "npm --workspace @opsprobe/desktop run tauri build",
    "desktop:lint": "npm --workspace @opsprobe/desktop run lint",
    "desktop:typecheck": "npm --workspace @opsprobe/desktop run typecheck",
    "local-service:serve": "npm --workspace @opsprobe/local-service run serve",
    "local-service:status": "npm --workspace @opsprobe/local-service run status"
    ,
    "local-service:stop": "npm --workspace @opsprobe/local-service run stop"
  }
}
